    hr { border: none; border-top: 1px solid var(--green-light); margin: 40px 0; }
    a { color: var(--green-mid); }
    .meta { font-size: 0.8rem; color: #888780; text-align: center; }
    footer { background: var(--green-dark); color: var(--green-light); text-align: center; padding: 32px 24px; font-size: 0.8rem; }
